:root {
    --ink: #111111;
    --muted: #6f6f6f;
    --line: #e9e5df;
    --paper: #fbfaf7;
    --white: #ffffff;
    --red: #d94b4b;
    --red-dark: #b93636;
    --green: #173c32;
    --shadow: 0 20px 60px rgba(17, 17, 17, 0.08);
    --radius: 8px;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html {
    scroll-behavior: smooth;
}

body {
    min-height: 100vh;
    background: var(--paper);
    color: var(--ink);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.5;
}

img {
    display: block;
    max-width: 100%;
}

button,
input,
select,
textarea {
    font: inherit;
}

button,
a {
    -webkit-tap-highlight-color: transparent;
}

a {
    color: inherit;
    text-decoration: none;
}

.page-shell {
    overflow: hidden;
}

.container {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
}

.hero {
    position: relative;
    min-height: calc(100vh - 82px);
    display: grid;
    align-items: center;
    padding: 60px 0 76px;
    background:
        radial-gradient(circle at 83% 22%, rgba(217, 75, 75, 0.13), transparent 28%),
        linear-gradient(120deg, rgba(255, 255, 255, 0.88), rgba(251, 250, 247, 0.9));
}

.hero::before {
    position: absolute;
    inset: auto -90px -160px auto;
    width: 520px;
    height: 520px;
    content: "";
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 50%;
}

.hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1.1fr);
    align-items: center;
    gap: 62px;
}

.eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    color: var(--red-dark);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 13px;
    font-weight: 750;
}

.eyebrow::before {
    width: 34px;
    height: 2px;
    content: "";
    background: var(--red);
}

h1 {
    max-width: 640px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(52px, 8vw, 92px);
    line-height: 0.95;
    letter-spacing: 0;
}

h1 span {
    color: var(--red);
}

.hero-copy {
    max-width: 520px;
    margin-top: 22px;
    color: #4d4d4d;
    font-size: 18px;
}

.hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    margin-top: 32px;
}

.button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 48px;
    padding: 0 22px;
    color: var(--white);
    background: var(--ink);
    border: 1px solid var(--ink);
    border-radius: 999px;
    cursor: pointer;
    font-weight: 800;
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
}

.button:hover {
    background: var(--red-dark);
    border-color: var(--red-dark);
    transform: translateY(-2px);
}

.button:disabled {
    cursor: not-allowed;
    opacity: 0.45;
    transform: none;
}

.button.secondary {
    color: var(--ink);
    background: transparent;
    border-color: var(--line);
}

.button.secondary:hover {
    color: var(--white);
    background: var(--ink);
    border-color: var(--ink);
}

.button svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
}

.hero-badges {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    max-width: 560px;
    margin-top: 52px;
}

.badge {
    padding-top: 18px;
    border-top: 1px solid var(--line);
}

.badge strong {
    display: block;
    font-size: 15px;
}

.badge span {
    display: block;
    margin-top: 4px;
    color: var(--muted);
    font-size: 13px;
}

.hero-visual {
    position: relative;
    min-height: 570px;
}

.code-window {
    position: absolute;
    top: 0;
    right: 0;
    width: min(100%, 560px);
    padding: 18px;
    color: #f5f2ee;
    background: #101010;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
}

.window-dots {
    display: flex;
    gap: 8px;
    margin-bottom: 18px;
}

.window-dots span {
    width: 11px;
    height: 11px;
    background: var(--red);
    border-radius: 50%;
}

.window-dots span:nth-child(2) {
    background: #f3c45f;
}

.window-dots span:nth-child(3) {
    background: #78c275;
}

.code-lines {
    display: grid;
    gap: 9px;
    color: rgba(255, 255, 255, 0.82);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: clamp(12px, 1.7vw, 15px);
}

.code-lines b {
    color: #ff7777;
    font-weight: 700;
}

.code-lines em {
    color: #f5d58d;
    font-style: normal;
}

.plate {
    position: absolute;
    right: 20px;
    bottom: 16px;
    display: grid;
    place-items: center;
    width: min(92vw, 520px);
    aspect-ratio: 1;
    background:
        radial-gradient(circle, #f8f5ee 0 48%, #e8e1d6 49% 50%, #fbfaf7 51% 66%, #d8d0c4 67% 68%, #f7f3ec 69%);
    border-radius: 50%;
    box-shadow: 0 32px 80px rgba(17, 17, 17, 0.14);
}

.sushi-board {
    display: grid;
    grid-template-columns: repeat(4, 72px);
    gap: 15px;
    transform: rotate(-8deg);
}

.roll {
    position: relative;
    width: 72px;
    height: 72px;
    background: #111111;
    border: 6px solid #111111;
    border-radius: 50%;
    box-shadow: inset 0 0 0 10px #f8f4ec;
}

.roll::before {
    position: absolute;
    inset: 18px;
    content: "";
    background: var(--red);
    border-radius: 50%;
    box-shadow: 10px 0 0 #f7c45e, -8px 6px 0 #67a768;
}

.roll:nth-child(2n) {
    box-shadow: inset 0 0 0 10px #fff9f0;
}

.roll:nth-child(3n)::before {
    background: #ee8f52;
    box-shadow: 9px -2px 0 #78a36d, -9px 5px 0 #f2d482;
}

.nigiri {
    position: absolute;
    left: -8px;
    bottom: 78px;
    width: 178px;
    height: 70px;
    background: #fffdf8;
    border-radius: 36px;
    box-shadow: 0 13px 25px rgba(17, 17, 17, 0.14);
    transform: rotate(14deg);
}

.nigiri::before {
    position: absolute;
    inset: -12px 12px 22px;
    content: "";
    background: repeating-linear-gradient(115deg, #ee7659 0 15px, #f39c7d 16px 23px);
    border-radius: 36px;
}

.terminal-chip {
    position: absolute;
    left: 20px;
    bottom: 24px;
    max-width: 240px;
    padding: 14px 16px;
    color: var(--white);
    background: var(--red);
    border-radius: var(--radius);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 18px 36px rgba(185, 54, 54, 0.25);
}

section {
    padding: 78px 0;
}

.section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 34px;
}

.section-kicker {
    color: var(--red-dark);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
}

h2 {
    margin-top: 8px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1;
    letter-spacing: 0;
}

.section-head p {
    max-width: 380px;
    color: var(--muted);
}

.menu-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
}

.menu-card {
    overflow: hidden;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: 0 14px 32px rgba(17, 17, 17, 0.04);
}

.dish-art {
    position: relative;
    display: grid;
    place-items: center;
    height: 180px;
    background:
        linear-gradient(135deg, rgba(217, 75, 75, 0.08), rgba(255, 255, 255, 0.4)),
        #f3efe8;
}

.dish-art::before {
    width: 126px;
    height: 126px;
    content: "";
    background: radial-gradient(circle, #fbfaf7 0 60%, #dfd5c8 61% 63%, #fbfaf7 64%);
    border-radius: 50%;
    box-shadow: 0 16px 30px rgba(17, 17, 17, 0.09);
}

.dish-art .mini-rolls {
    position: absolute;
    display: grid;
    grid-template-columns: repeat(2, 34px);
    gap: 7px;
    transform: rotate(-8deg);
}

.mini-rolls i {
    position: relative;
    width: 34px;
    height: 34px;
    background: #111;
    border: 4px solid #111;
    border-radius: 50%;
    box-shadow: inset 0 0 0 5px #fff7ef;
}

.mini-rolls i::before {
    position: absolute;
    inset: 10px;
    content: "";
    background: var(--red);
    border-radius: 50%;
}

.dish-art.sashimi .mini-rolls {
    grid-template-columns: repeat(3, 42px);
    gap: 4px;
    transform: rotate(-16deg);
}

.dish-art.sashimi .mini-rolls i {
    width: 42px;
    height: 26px;
    background: repeating-linear-gradient(110deg, #ee7659 0 9px, #f7a080 10px 14px);
    border: 0;
    border-radius: 18px;
    box-shadow: 0 7px 12px rgba(17, 17, 17, 0.12);
}

.dish-art.sashimi .mini-rolls i::before {
    display: none;
}

.dish-art.temaki .mini-rolls {
    width: 100px;
    height: 116px;
    display: block;
    background: conic-gradient(from 235deg, #111 0 85deg, transparent 86deg);
    transform: rotate(-18deg);
}

.dish-art.temaki .mini-rolls::before {
    position: absolute;
    top: 22px;
    left: 22px;
    width: 44px;
    height: 44px;
    content: "";
    background: radial-gradient(circle at 55% 35%, #f9d99e 0 18%, #ef7458 19% 47%, #fff7ef 48%);
    border-radius: 50%;
}

.dish-art.temaki .mini-rolls i {
    display: none;
}

.favorite {
    position: absolute;
    top: 12px;
    right: 12px;
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    color: var(--ink);
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid var(--line);
    border-radius: 50%;
    cursor: pointer;
}

.favorite svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
}

.favorite.active {
    color: var(--red);
    background: #fff0f0;
    border-color: rgba(217, 75, 75, 0.28);
}

.favorite.active svg {
    fill: currentColor;
}

.card-body {
    padding: 18px;
}

.card-body h3 {
    font-size: 18px;
    line-height: 1.2;
}

.card-body p {
    min-height: 44px;
    margin-top: 8px;
    color: var(--muted);
    font-size: 14px;
}

.price-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 20px;
}

.price {
    font-size: 17px;
    font-weight: 850;
}

.add-button {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    color: var(--white);
    background: var(--ink);
    border: 0;
    border-radius: 50%;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
}

.add-button:hover {
    background: var(--red-dark);
    transform: translateY(-2px);
}

.add-button svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
}

.combo {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    align-items: center;
    gap: 36px;
    padding: 42px;
    color: var(--white);
    background:
        linear-gradient(120deg, rgba(17, 17, 17, 0.94), rgba(17, 17, 17, 0.75)),
        url("identidade.jpg") center / cover;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
}

.combo h2 {
    color: var(--white);
}

.combo p {
    max-width: 390px;
    margin: 16px 0 28px;
    color: rgba(255, 255, 255, 0.78);
}

.combo-code {
    padding: 28px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: clamp(13px, 2vw, 18px);
}

.combo-code div {
    padding: 7px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.combo-code div:last-child {
    border-bottom: 0;
}

.features {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius);
}

.feature {
    display: flex;
    gap: 16px;
    min-height: 150px;
    padding: 28px;
    background: var(--white);
}

.feature svg {
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    color: var(--red-dark);
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
}

.feature h3 {
    margin-bottom: 6px;
    font-size: 17px;
}

.feature p {
    color: var(--muted);
    font-size: 14px;
}

.about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 54px;
    align-items: center;
}

.about-visual {
    min-height: 420px;
    background:
        linear-gradient(135deg, rgba(217, 75, 75, 0.05), rgba(255, 255, 255, 0.66)),
        url("site.png") center top / cover;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
}

.about p {
    margin-top: 18px;
    color: var(--muted);
    font-size: 17px;
}

.stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 32px;
}

.stat {
    padding: 18px;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
}

.stat strong {
    display: block;
    font-size: 26px;
}

.stat span {
    color: var(--muted);
    font-size: 13px;
}

.contact-band {
    padding: 42px;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
}

.contact-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: center;
}

.contact-content p {
    max-width: 450px;
    margin-top: 12px;
    color: var(--muted);
}

.newsletter {
    display: flex;
    gap: 10px;
}

.newsletter input {
    min-width: 0;
    width: 100%;
    min-height: 50px;
    padding: 0 18px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 999px;
    outline: 0;
}

.newsletter input:focus {
    border-color: var(--red);
}

footer {
    padding: 34px 0;
    color: var(--muted);
    font-size: 14px;
}

.footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    border-top: 1px solid var(--line);
    padding-top: 26px;
}

.toast {
    position: fixed;
    right: 22px;
    bottom: 22px;
    z-index: 30;
    transform: translateY(24px);
    opacity: 0;
    min-width: 250px;
    padding: 14px 16px;
    color: var(--white);
    background: var(--ink);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
}

.toast.show {
    transform: translateY(0);
    opacity: 1;
}

body.no-scroll {
    overflow: hidden;
}

.drawer-backdrop {
    position: fixed;
    inset: 0;
    z-index: 35;
    background: rgba(17, 17, 17, 0.42);
    backdrop-filter: blur(5px);
}

.cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    z-index: 40;
    display: grid;
    grid-template-rows: auto 1fr auto;
    width: min(440px, 100%);
    height: 100vh;
    padding: 26px;
    background: var(--paper);
    border-left: 1px solid var(--line);
    box-shadow: -24px 0 70px rgba(17, 17, 17, 0.18);
    transform: translateX(102%);
    transition: transform 0.24s ease;
}

.cart-drawer.open {
    transform: translateX(0);
}

.cart-header,
.modal-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
}

.cart-header h2,
.modal-head h2 {
    font-size: 34px;
}

.cart-items {
    display: grid;
    align-content: start;
    gap: 14px;
    overflow-y: auto;
    padding: 24px 4px 24px 0;
}

.cart-item {
    display: grid;
    grid-template-columns: 58px 1fr;
    gap: 14px;
    padding: 14px;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
}

.cart-item-art {
    display: grid;
    place-items: center;
    width: 58px;
    height: 58px;
    background: #f3efe8;
    border-radius: 50%;
}

.cart-item-art::before {
    width: 36px;
    height: 36px;
    content: "";
    background: #111;
    border: 4px solid #111;
    border-radius: 50%;
    box-shadow: inset 0 0 0 6px #fff7ef;
}

.cart-item-info {
    min-width: 0;
}

.cart-item-info h3 {
    font-size: 16px;
    line-height: 1.25;
}

.cart-item-info p {
    margin-top: 4px;
    color: var(--muted);
    font-size: 13px;
}

.cart-item-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 12px;
}

.quantity-control {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 999px;
}

.quantity-control button {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    color: var(--ink);
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 50%;
    cursor: pointer;
}

.quantity-control span {
    min-width: 22px;
    text-align: center;
    font-weight: 800;
}

.cart-line-total {
    font-weight: 850;
    white-space: nowrap;
}

.remove-item {
    color: var(--muted);
    background: transparent;
    border: 0;
    cursor: pointer;
    font-size: 13px;
    font-weight: 750;
}

.remove-item:hover {
    color: var(--red-dark);
}

.cart-empty {
    display: grid;
    place-items: center;
    align-content: center;
    gap: 8px;
    min-height: 240px;
    color: var(--muted);
    text-align: center;
}

.cart-empty strong {
    color: var(--ink);
    font-size: 18px;
}

.cart-empty.hidden {
    display: none;
}

.cart-summary {
    display: grid;
    gap: 12px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
}

.cart-summary > div,
.checkout-total {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    color: var(--muted);
}

.cart-summary strong,
.checkout-total strong {
    color: var(--ink);
}

.summary-total {
    padding-top: 12px;
    border-top: 1px solid var(--line);
    font-size: 18px;
}

.summary-total strong,
.checkout-total strong {
    font-size: 22px;
}

.checkout-button {
    width: 100%;
    margin-top: 8px;
}

.checkout-modal {
    position: fixed;
    inset: 0;
    z-index: 45;
    display: grid;
    place-items: center;
    padding: 22px;
    background: rgba(17, 17, 17, 0.48);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
}

.checkout-modal.open {
    opacity: 1;
    pointer-events: auto;
}

.modal-panel {
    width: min(620px, 100%);
    max-height: calc(100vh - 44px);
    overflow-y: auto;
    padding: 28px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
}

.checkout-form {
    display: grid;
    gap: 16px;
    margin-top: 24px;
}

.form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
}

.checkout-form label {
    display: grid;
    gap: 8px;
    color: var(--ink);
    font-size: 14px;
    font-weight: 800;
}

.checkout-form input,
.checkout-form select,
.checkout-form textarea {
    width: 100%;
    min-height: 48px;
    padding: 0 15px;
    color: var(--ink);
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    outline: 0;
}

.checkout-form textarea {
    min-height: 92px;
    padding-top: 12px;
    resize: vertical;
}

.checkout-form input:focus,
.checkout-form select:focus,
.checkout-form textarea:focus {
    border-color: var(--red);
}

.checkout-total {
    padding: 16px;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
}

@media (max-width: 960px) {
    .hero {
        min-height: auto;
        padding-top: 48px;
    }

    .hero-grid,
    .about,
    .combo,
    .contact-content {
        grid-template-columns: 1fr;
    }

    .hero-visual {
        min-height: 520px;
    }

    .menu-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .features {
        grid-template-columns: 1fr;
    }

    .about-visual {
        min-height: 340px;
    }
}

@media (max-width: 640px) {
    .container {
        width: min(100% - 28px, 1120px);
    }

    .hero-badges,
    .menu-grid,
    .stats {
        grid-template-columns: 1fr;
    }

    .hero-visual {
        min-height: 430px;
    }

    .code-window {
        width: 100%;
        padding: 14px;
    }

    .plate {
        right: 50%;
        bottom: 4px;
        width: min(88vw, 350px);
        transform: translateX(50%);
    }

    .sushi-board {
        grid-template-columns: repeat(4, 48px);
        gap: 9px;
    }

    .roll {
        width: 48px;
        height: 48px;
        border-width: 4px;
        box-shadow: inset 0 0 0 7px #f8f4ec;
    }

    .roll::before {
        inset: 12px;
    }

    .nigiri {
        width: 124px;
        height: 50px;
        bottom: 54px;
        left: 4px;
    }

    .terminal-chip {
        display: none;
    }

    .section-head {
        display: block;
    }

    .section-head p {
        margin-top: 12px;
    }

    .combo,
    .contact-band {
        padding: 28px 20px;
    }

    .newsletter {
        flex-direction: column;
    }

    .newsletter .button {
        width: 100%;
    }

    .cart-drawer {
        padding: 22px 18px;
    }

    .form-grid {
        grid-template-columns: 1fr;
    }

    .footer-row {
        flex-direction: column;
        align-items: flex-start;
    }
}
